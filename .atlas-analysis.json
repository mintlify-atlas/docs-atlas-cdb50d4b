  "keyFeatures": [
    "Semver versioning with permission escalation detection",
    "Deterministic lockfiles with SHA-512 integrity verification",
    "Permission model with install-time enforcement",
    "6-stage security pipeline (structure, static analysis, injection detection, secrets, supply chain)",
    "Transparent 0-10 audit scores",
    "GitHub OAuth authentication with API key management",
    "Web registry with organization support",
    "Agent linking for multi-agent workspaces",
    "Full-text search with skill discovery",
    "Enterprise SSO and on-premises deployment support"
  ],
